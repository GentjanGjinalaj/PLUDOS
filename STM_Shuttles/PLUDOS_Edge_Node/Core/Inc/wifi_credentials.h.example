/* wifi_credentials.h.example — committed template.
 * Copy to wifi_credentials.h (gitignored) and fill in real values before building. */
#ifndef WIFI_CREDENTIALS_H
#define WIFI_CREDENTIALS_H

#define WIFI_SSID     "your_ssid_here"
#define WIFI_PASSWORD "your_password_here"
#define JETSON_IP     "0.0.0.0"          /* Fallback if beacon discovery times out; set to actual IP for networks without beacon */
#define SHUTTLE_ID    1U                 /* 1-based integer, unique per device (1, 2, 3…)         */

#endif /* WIFI_CREDENTIALS_H */

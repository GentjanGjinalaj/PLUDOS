/* wifi_credentials.h.example — committed template.
 * Copy to wifi_credentials.h (gitignored) and fill in real values before building.
 *
 * SHUTTLE_ID must be UNIQUE per physical STM32 device. The 3-Jetson dev rig
 * uses the following layout:
 *
 *   SHUTTLE_ID  Bonded Jetson   Beacon group seen on the wire
 *   ----------  -------------   ----------------------------------
 *        1      jetson-1         PLUDOS-GW:<ip>:1,2
 *        2      jetson-1         PLUDOS-GW:<ip>:1,2
 *        3      jetson-2         PLUDOS-GW:<ip>:3,4
 *        4      jetson-2         PLUDOS-GW:<ip>:3,4
 *        5      jetson-3         PLUDOS-GW:<ip>:5,6
 *        6      jetson-3         PLUDOS-GW:<ip>:5,6
 *
 * The firmware bonds to the first Jetson whose beacon lists this SHUTTLE_ID;
 * beacons from other Jetsons (e.g. SHUTTLE_GROUP=3,4 when this device is ID 1)
 * are silently ignored. JETSON_IP below is the compile-time fallback used
 * only if the boot-time beacon search times out (30 s).
 */
#ifndef WIFI_CREDENTIALS_H
#define WIFI_CREDENTIALS_H

#define WIFI_SSID     "your_ssid_here"
#define WIFI_PASSWORD "your_password_here"
#define JETSON_IP     "0.0.0.0"          /* Fallback if beacon discovery times out; set to actual IP for networks without beacon */
#define SHUTTLE_ID    1U                 /* 1-based integer, UNIQUE per device (range 1..6 for the 3-Jetson dev rig) */

#endif /* WIFI_CREDENTIALS_H */

# PLUDOS Alumet server-side energy profiler
# Two-stage build: Rust toolchain for build, minimal Debian for runtime.
# First build is slow (~10 min) due to Rust compilation; subsequent builds
# use the cargo registry layer cache.
#
# RAPL requirement: the host must expose /sys/class/powercap (Intel RAPL).
# Mount it read-only via compose.yaml. On AMD or VMs without RAPL, Alumet
# falls back to process-level CPU accounting (less accurate).
#
# Phase 2 (ADR-011): relay-in receives metric streams from Jetson alumet-relay
# sidecars over gRPC (Tailscale VPN).  Each Jetson forwards INA3221 readings;
# this instance aggregates them with server RAPL data and writes to InfluxDB.
#
# Prometheus exporter runs on port 9091 for live Grafana scraping.
# InfluxDB output runs in parallel for persistent storage.

# ---- Stage 1: build alumet-cli -----------------------------------------
FROM rust:1.78-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# TODO: pin version (e.g. alumet-cli@0.x.y) once relay flag names are verified.
RUN cargo install alumet-cli

# ---- Stage 2: minimal runtime image ------------------------------------
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/cargo/bin/alumet-cli /usr/local/bin/alumet-cli

# Plugins:
#   --plugin rapl          : Intel RAPL CPU energy from /sys/class/powercap (host mount)
#   --relay-in             : receive INA3221 streams from Jetson alumet-relay sidecars
# Outputs (both run simultaneously):
#   --output influxdb      : persistent time-series storage
#   --output prometheus    : live scrape endpoint for Grafana on port 9091
# Tags:
#   device=$ALUMET_DEVICE_TAG : identifies server in multi-device dashboards
#
# NOTE: --relay-in flag name confirmed from Alumet docs.
# NOTE: --output influxdb / --influxdb-* flag names assumed from common Alumet CLI
#       conventions — verify with `alumet-cli --help` after installation.
CMD ["sh", "-c", \
     "alumet-cli \
       --plugin rapl \
       --relay-in 0.0.0.0:${ALUMET_RELAY_PORT:-50051} \
       --output influxdb \
       --influxdb-url ${INFLUXDB_URL} \
       --influxdb-token ${INFLUXDB_TOKEN} \
       --influxdb-org ${INFLUXDB_ORG} \
       --influxdb-bucket ${INFLUXDB_BUCKET} \
       --output prometheus \
       --tag device=${ALUMET_DEVICE_TAG:-server}"]

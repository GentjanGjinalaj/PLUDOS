# PLUDOS Alumet server-side energy profiler — x86_64 (laptop / future server)
# Builds alumet-agent from source at v0.9.4. Same pattern as client/alumet-relay/Containerfile.
#
# Plugins loaded at runtime (entrypoint.sh):
#   rapl               — Intel/AMD CPU energy via /sys/class/powercap (host mount in compose.yaml)
#   relay-server       — gRPC receiver for Jetson alumet-relay streams (port 50051)
#   influxdb           — persistent write to InfluxDB
#   prometheus-exporter — live Grafana scrape on port 9091
#
# First build is slow (~20 min); subsequent builds use cargo registry layer cache.

# ---- Stage 1: build alumet-agent ----------------------------------------
# rust:slim tracks latest stable — required because alumet-agent needs Rust ≥ 1.89.
FROM docker.io/library/rust:slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install alumet-agent from the alumet monorepo (not published on crates.io).
# Pinned to v0.9.4 for reproducibility — update when upgrading alumet.
RUN cargo install \
    --git https://github.com/alumet-dev/alumet \
    --tag v0.9.4 \
    alumet-agent

# ---- Stage 2: minimal runtime ------------------------------------------
# Must match the builder's Debian base so GLIBC versions align.
# rust:slim currently resolves to Debian 13 (trixie, GLIBC 2.39).
FROM docker.io/library/debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/cargo/bin/alumet-agent /usr/local/bin/alumet-agent
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

CMD ["/usr/local/bin/entrypoint.sh"]

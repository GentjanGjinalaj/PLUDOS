{
  "id": null,
  "uid": "pludos-main",
  "title": "PLUDOS System Monitor",
  "description": "Shuttle drains \u00b7 vibration \u00b7 environment \u00b7 Jetson INA3221 power \u00b7 FL energy + training",
  "tags": [
    "pludos"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\u25c9 Live Status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Drains \u2014 Last 24 h",
      "description": "Total drains (idle snapshots + missions, all shuttles) received in the last 24 h.",
      "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket:\"alumet_energy\") |> range(start: -24h) |> filter(fn: (r) => r._measurement == \"stm_mission\" and r._field == \"packets_total\" and r.source == \"drain\") |> group() |> count() |> yield(name: \"A\")",
          "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" }
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Last Drain Loss %",
      "description": "Packet loss of the most recent drain (any shuttle). Phase-1 has no retransmit, so this is the raw blast loss.",
      "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket:\"alumet_energy\") |> range(start: -24h) |> filter(fn: (r) => r._measurement == \"stm_mission\" and r._field == \"loss_pct\" and r.source == \"drain\") |> group() |> last() |> yield(name: \"A\")",
          "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" }
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 2, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Last Accel Peak (g)",
      "description": "Peak accel magnitude of the most recent drain (any shuttle).",
      "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket:\"alumet_energy\") |> range(start: -24h) |> filter(fn: (r) => r._measurement == \"stm_mission\" and r._field == \"accel_peak_g\" and r.source == \"drain\") |> group() |> last() |> yield(name: \"A\")",
          "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" }
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "accG",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Jetson Board Power (W)",
      "description": "Live INA3221 board power = last input_current \u00d7 last input_voltage. Same source as the Jetson Power row below.",
      "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" },
      "targets": [
        {
          "refId": "A",
          "query": "cur = from(bucket:\"alumet_energy\") |> range(start: -5m) |> filter(fn: (r) => r._measurement == \"input_current\" and r._field == \"value\") |> aggregateWindow(every: 30s, fn: mean, createEmpty: false) |> keep(columns: [\"_time\", \"_value\"]) |> rename(columns: {_value: \"i_ma\"}) volt = from(bucket:\"alumet_energy\") |> range(start: -5m) |> filter(fn: (r) => r._measurement == \"input_voltage\" and r._field == \"value\") |> aggregateWindow(every: 30s, fn: mean, createEmpty: false) |> keep(columns: [\"_time\", \"_value\"]) |> rename(columns: {_value: \"u_mv\"}) join(tables: {c: cur, v: volt}, on: [\"_time\"]) |> map(fn: (r) => ({_time: r._time, _value: r.i_ma * r.u_mv / 1000000.0})) |> last() |> yield(name: \"A\")",
          "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" }
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 15, "color": "yellow" },
              { "value": 22, "color": "red" }
            ]
          }
        }
      }
    },

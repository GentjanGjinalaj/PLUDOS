      "type": "table",
      "title": "All Missions \u2014 last 24 h",
      "datasource": {
        "type": "influxdb",
        "uid": "efmtstss6rcw0d"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket:\"alumet_energy\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"stm_mission\")\n  |> pivot(rowKey: [\"_time\",\"shuttle_id\",\"gateway\",\"kind\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"_time\",\"shuttle_id\",\"kind\",\"packets_received\",\"packets_total\",\"loss_pct\",\"accel_samples\",\"gyro_samples\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 100)",
          "datasource": {
            "type": "influxdb",
            "uid": "efmtstss6rcw0d"
          }
        }

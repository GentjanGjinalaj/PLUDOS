    {
      "id": 20,
      "type": "timeseries",
      "title": "Board Input Power (W)",
      "datasource": {
        "type": "influxdb",
        "uid": "efmtstss6rcw0d"
      },
      "targets": [
        {
          "refId": "A",
          "query": "c = from(bucket:\"alumet_energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"input_current\" and r._field == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> rename(columns: {_value: \"current_ma\"})\n\nv2 = from(bucket:\"alumet_energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"input_voltage\" and r._field == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> rename(columns: {_value: \"voltage_mv\"})\n\njoin(tables: {c: c, v: v2}, on: [\"_time\", \"resource_consumer_kind\", \"resource_kind\"])\n  |> map(fn: (r) => ({r with _value: r.current_ma * r.voltage_mv / 1.0e6}))\n  |> yield(name: \"A\")",
          "datasource": {
            "type": "influxdb",
            "uid": "efmtstss6rcw0d"
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 22
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "max": 25
        }
      }
    },

      "datasource": {
        "type": "influxdb",
        "uid": "efmtstss6rcw0d"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"alumet_energy\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"stm_telemetry\" and r._field == \"state\" and r.shuttle_id == \"1\")\n  |> last()\n  |> yield(name: \"A\")",
          "datasource": {
            "type": "influxdb",
            "uid": "efmtstss6rcw0d"
          }
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "mappings": [
          {
            "type": "value",
            "options": {
              "0": {
                "text": "IDLE",
                "color": "blue",
                "index": 0
              },
              "1": {
                "text": "MOVING",
                "color": "green",
                "index": 1
              }
            }

      "title": "Board Input Power (W)",
      "description": "Power = input_current \u00d7 input_voltage, joined per time window.",
      "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" },
      "targets": [
        {
          "refId": "A",
          "query": "cur = from(bucket:\"alumet_energy\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"input_current\" and r._field == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> keep(columns: [\"_time\", \"_value\"]) |> rename(columns: {_value: \"i_ma\"}) volt = from(bucket:\"alumet_energy\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"input_voltage\" and r._field == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> keep(columns: [\"_time\", \"_value\"]) |> rename(columns: {_value: \"u_mv\"}) join(tables: {c: cur, v: volt}, on: [\"_time\"]) |> map(fn: (r) => ({_time: r._time, _value: r.i_ma * r.u_mv / 1000000.0})) |> yield(name: \"A\")",
          "datasource": { "type": "influxdb", "uid": "efmtstss6rcw0d" }
        }

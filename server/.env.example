# -------------------------------------------------------------------
# PLUDOS Central Server — environment template
# Copy to server/.env and fill in real values before starting.
#   cp server/.env.example server/.env
# NEVER commit server/.env — it is gitignored.
# Rotate all tokens/passwords before any non-local deployment.
# -------------------------------------------------------------------

# InfluxDB 2.7
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme              # rotate before non-local deploy
INFLUXDB_ADMIN_TOKEN=changeme-pludos-token   # rotate before non-local deploy
INFLUXDB_ORG=pludos
INFLUXDB_BUCKET=alumet_energy

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme              # rotate before non-local deploy

# Alumet server-side energy profiler
# ALUMET_RELAY_PORT: gRPC port for receiving Jetson relay streams (ADR-011 Phase 2)
ALUMET_RELAY_PORT=50051

# ---------------------------------------------------------------------------
# server.py (Flower ServerApp) — energy-aware adaptation (ADR-014)
# These are read by the Flower process (started with `flwr run .`), NOT by the
# InfluxDB/Grafana containers. Export them in your shell or add to a shell profile.
# ---------------------------------------------------------------------------

# InfluxDB connection for server.py to query post-round energy measurements.
# URL is localhost because server.py runs on the same machine as the InfluxDB container.
# TOKEN must match INFLUXDB_ADMIN_TOKEN above.
INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_TOKEN=changeme-pludos-token     # must match INFLUXDB_ADMIN_TOKEN above
INFLUXDB_ORG=pludos
INFLUXDB_BUCKET=alumet_energy

# Energy budget and n_estimators bounds for adaptive training (ADR-014).
#
# Calibration procedure (run once on real Jetson hardware):
#   1. Set FL_N_ESTIMATORS_DEFAULT to your target value (e.g. 10).
#   2. Run 5+ FL rounds: PYTHONPATH=server:client flwr run .
#   3. Query InfluxDB for round_total phase energy:
#        from(bucket:"alumet_energy") |> range(start:-2h)
#        |> filter(fn:(r)=>r._measurement=="fl_phases" and r._field=="energy_j" and r.phase=="round_total")
#   4. Compute mean across rounds. Set FL_ENERGY_BUDGET_J = mean × 0.85.
#
# TEST_MODE mock data (random 25–50 W × 1.5 s) produces ~58 J/round — not representative.
# The real Jetson Orin Nano at 7–25 W doing XGBoost on ~500 samples is expected to be
# significantly lower. Do not use mock values as the calibration baseline.
#
# 50.0 J is an uncalibrated placeholder. Uncomment and set after first hardware run.
# FL_ENERGY_BUDGET_J=50.0
# FL_N_ESTIMATORS_DEFAULT=10
# FL_N_ESTIMATORS_MIN=5
# FL_N_ESTIMATORS_MAX=20

# FL round configuration
# FL_NUM_ROUNDS=3
# FL_MIN_FIT_CLIENTS=1

# ---------------------------------------------------------------------------
# FL Trigger watcher (server/trigger/trigger.py) — autonomous `flwr run .`
# launcher running as the fl-trigger compose service. See
# docs/DEPLOYMENT_GUIDE.md §3.8 for the readiness logic and last_run.json schema.
# ---------------------------------------------------------------------------
# Poll period in seconds — how often the trigger checks InfluxDB for ready gateways.
# FL_TRIGGER_INTERVAL_S=30
#
# Minimum ready gateways before firing a round. Keep aligned with
# FL_MIN_FIT_CLIENTS above so the trigger and the Flower strategy agree on the quorum.
# (The compose service already inherits FL_MIN_FIT_CLIENTS — no separate var needed.)

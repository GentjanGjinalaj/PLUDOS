# PLUDOS client/ environment variables
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# Jetson identity — sets the container hostname so InfluxDB tags (device,
# gateway) are human-readable. MUST be unique per physical Jetson in a
# multi-Jetson deployment, otherwise InfluxDB merges metrics from different
# gateways under the same tag. For the 3-Jetson dev rig:
#   jetson-1  (serves shuttles 1,2)
#   jetson-2  (serves shuttles 3,4)
#   jetson-3  (serves shuttles 5,6)
# ---------------------------------------------------------------------------
JETSON_HOSTNAME=jetson-1

# ---------------------------------------------------------------------------
# Tailscale VPN (vpn profile only — ai-worker + tailscale services)
# Leave empty when running data-engine alone for local ingestion tests.
# ---------------------------------------------------------------------------
TS_AUTHKEY=

# ---------------------------------------------------------------------------
# InfluxDB — written by both ai-worker (fl_energy, fl_phases) and
# data-engine (stm_mission). These must match the values in server/.env.
# ---------------------------------------------------------------------------
INFLUXDB_URL=http://<server-tailscale-ip>:8086
INFLUXDB_TOKEN=pludos-secret-token
INFLUXDB_ORG=pludos
INFLUXDB_BUCKET=alumet_energy

# ---------------------------------------------------------------------------
# InfluxDB measurements written by this gateway:
#   fl_energy   — 10 Hz Jetson power samples per FL round (ai-worker)
#   fl_phases   — per-phase energy summary: load / train / round_total (ai-worker)
#   stm_mission — per-shuttle mission energy, packet count, duration (data-engine)
# All three share the same bucket. No extra config required.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Data engine tuning — all optional, defaults shown
# ---------------------------------------------------------------------------
# TEST_MODE=0                # 1 = write to ./ram_buffer; 0 = /app/ram_buffer (container)
# TELEMETRY_PORT=5683        # UDP port for the unified PludosTelemetry stream (ADR-015)
# MISSION_END_IDLE_S=30      # IDLE seconds after a MOVING run that flushes the mission
# STATUS_LOG_PERIOD_S=1.0    # gateway prints one summary line per shuttle per N seconds
# NTP_REFRESH_INTERVAL=100   # re-anchor NTP offset every N packets per shuttle
#
# Per-shuttle buffer limits (independent of other shuttles).
#   SHUTTLE_SOFT_LIMIT: proactive flush when THIS shuttle's buffer hits N packets.
#   SHUTTLE_HARD_LIMIT: emergency flush for THIS shuttle only (other shuttles unaffected).
#   GATEWAY_HARD_LIMIT: absolute ceiling across ALL shuttles combined (safety valve).
# At 50 Hz MOVING: SHUTTLE_SOFT=1000 → flush after 20 s, SHUTTLE_HARD=1500 → flush after 30 s.
# SHUTTLE_SOFT_LIMIT=1000
# SHUTTLE_HARD_LIMIT=1500
# GATEWAY_HARD_LIMIT=50000
#
# Shuttle name map — wire carries a 1-byte integer ID; gateway resolves to name here.
# Default already covers IDs 1-6 (Alpha/Beta/Charlie/Delta/Echo/Foxtrot) so the
# 3-Jetson dev rig works without overriding. Override per-Jetson only if you want
# different names per gateway.
# SHUTTLE_NAMES=1:STM32-Alpha,2:STM32-Beta,3:STM32-Charlie,4:STM32-Delta,5:STM32-Echo,6:STM32-Foxtrot
#
# Power estimates for energy integration — firmware no longer transmits power_mw.
# IDLE ≈ (MCU 15mA + sensors 2mA + WiFi assoc 10mA) × 3.3V = 89 mW (confirmed).
# MOVING: depends on WiFi TX duty at 50 Hz; measure with bench ammeter to calibrate.
# POWER_IDLE_MW=89
# POWER_MOVING_MW=260

# ---------------------------------------------------------------------------
# AI worker tuning — all optional, defaults shown
# ---------------------------------------------------------------------------
# MAX_PARQUET_FILES=20     # max Parquet files concatenated per FL round
#                          # prevents unbounded memory on long-running deployments
#
# Anomaly labelling backend — controls how pseudo-labels are generated for XGBoost.
# XGBoost federation and Flower protocol are the same regardless of which backend is set.
#
# ANOMALY_MODEL=isolation_forest_xgb   # default: IsolationForest on per-packet features
# ANOMALY_MODEL=lstm_autoencoder       # LSTM autoencoder on sliding windows of MOVING packets;
#                                      # catches temporal patterns (vibration, jitter profiles)
#                                      # that IF misses. Requires torch (included in image).
#                                      # Adds ~10 s preprocessing per FL round on Jetson CPU.
# ANOMALY_MODEL=threshold              # legacy: accel_z > ANOMALY_THRESHOLD_G rule; for debug only
#
# ANOMALY_THRESHOLD_G=0.8  # accel_z threshold (g) — only used when ANOMALY_MODEL=threshold
#                          # UNCALIBRATED — validate against real fault data before any claim
#
# IsolationForest tuning (ANOMALY_MODEL=isolation_forest_xgb):
# IF_CONTAMINATION=0.05        # fraction of MOVING packets expected to be anomalous
# IF_MIN_MOVING_SAMPLES=50     # below this count, falls back to threshold label
#
# LSTM autoencoder tuning (ANOMALY_MODEL=lstm_autoencoder):
# LSTM_WINDOW_SIZE=50          # packets per window (50 = 5 s at 10 Hz MOVING rate)
# LSTM_HIDDEN_DIM=32           # encoder hidden size; larger = more expressive, slower
# LSTM_EPOCHS=20               # training epochs per FL round (~10 s on Jetson CPU)
# LSTM_BATCH_SIZE=32
# LSTM_MIN_MOVING_SAMPLES=200  # below this count, falls back to IsolationForest
#
# FL_N_ESTIMATORS_DEFAULT=10  # XGBoost n_estimators when no server override present

# ---------------------------------------------------------------------------
# Beacon broadcast — P2-1 zero-touch provisioning (STM32 auto-discovery)
# Note: broadcast only reaches the local WiFi subnet when data-engine runs
# with host networking (network_mode: host in compose.yaml) on the Jetson.
# ---------------------------------------------------------------------------
# GATEWAY_IP=              # Jetson WiFi IP to include in beacon payload.
#                          # Auto-detected via outbound UDP socket if unset.
# BEACON_PORT=5000
# BEACON_INTERVAL_S=10
#
# SHUTTLE_GROUP — comma-separated shuttle IDs this gateway serves. The beacon
# payload becomes "PLUDOS-GW:<ip>:<csv-ids>" and STMs accept it only if their
# SHUTTLE_ID is in the list. ALSO acts as an ingress filter — packets from
# shuttle IDs outside the group are dropped. Required in multi-Jetson
# deployments to prevent random STM↔Jetson bonding. Empty = accept all.
#   jetson-1: SHUTTLE_GROUP=1,2
#   jetson-2: SHUTTLE_GROUP=3,4
#   jetson-3: SHUTTLE_GROUP=5,6
SHUTTLE_GROUP=1,2

# ---------------------------------------------------------------------------
# Alumet relay sidecar (ADR-011 Phase 2) — alumet-relay service
#
# ALUMET_SERVER_ADDR: Tailscale IP:port of the server Alumet instance.
#   Set this to activate relay mode (alumet-cli --relay-out).
#   Leave empty for local-only mode (alumet-cli writes directly to InfluxDB).
#
# ALUMET_RELAY_METRICS_FILE: path to the shared file written by probe.py.
#   probe.py is currently dormant — alumet-cli with the native Jetson plugin
#   is the primary INA3221 reader. This var is only needed if probe.py is
#   revived as a fallback (see client/alumet-relay/probe.py for details).
# ---------------------------------------------------------------------------
# ALUMET_SERVER_ADDR=100.x.x.x:50051
# ALUMET_RELAY_METRICS_FILE=/app/power_metrics/latest.json  # (probe.py fallback only)

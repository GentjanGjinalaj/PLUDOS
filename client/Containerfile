# python:3.10-slim matches JetPack 6 (R36) host Python and avoids the
# BSP mismatch from l4t-pytorch:r35 (JetPack 5, Python 3.8).
# GPU access for ai-worker requires a JetPack 6 CUDA image — tracked separately.
FROM docker.io/library/python:3.10-slim

# Set the working directory inside the container
WORKDIR /app

# Copy your requirements and install them
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# Cache-bust: podman 3.4.4 (rootless overlay) can reuse the COPY layers below even
# when the .py files change, shipping stale code. A build ARG set to the git SHA on
# every deploy invalidates this RUN, which cascades to re-run the code COPYs — while
# the expensive pip layer above stays cached. Pass via compose build arg CODE_VERSION.
ARG CODE_VERSION=dev
RUN echo "$CODE_VERSION" > /app/.code_version

# Copy your Python scripts into the container
COPY data-engine.py .
COPY drain_receiver.py .
COPY ota_server.py .
COPY client.py .
COPY anomaly.py .
COPY anomaly_cnn.py .

# Create the internal buffer directory
RUN mkdir -p /app/ram_buffer
# PLUDOS Alumet relay sidecar — Jetson Orin Nano (ARM64)
# Builds alumet-agent from source (workspace crate: agent/, binary: alumet-agent).
# INA3221 is read natively via the nvidia-jetson plugin compiled into the agent.
#
# On the Jetson (ARM64), rust:slim resolves to the arm64 variant automatically.
# Build on the Jetson directly or cross-compile with --platform linux/arm64.
#
# First build is slow (~20–30 min on Jetson) due to Rust + full workspace compile.
# Subsequent builds use the cargo registry and git layer cache.
#
# ADR-011 Phase 2 — two runtime modes (see entrypoint.sh):
#   Local mode:  ALUMET_SERVER_ADDR unset — alumet-agent writes directly to InfluxDB.
#   Relay mode:  ALUMET_SERVER_ADDR set   — alumet-agent relays stream to server Alumet.
#
# After first build, verify actual flag names with: alumet-agent --help
# Then update entrypoint.sh if --plugin, --relay-out, or --output flags differ.

# ---- Stage 1: build alumet-agent ----------------------------------------
# rust:slim tracks latest stable — required because alumet-agent needs Rust ≥ 1.89.
FROM docker.io/library/rust:slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install alumet-agent from the alumet monorepo (not published on crates.io).
# Pinned to v0.9.4 for reproducibility — update when upgrading alumet.
RUN cargo install \
    --git https://github.com/alumet-dev/alumet \
    --tag v0.9.4 \
    alumet-agent

# ---- Stage 2: minimal runtime ------------------------------------------
# Must match the builder's Debian base so GLIBC versions align.
# rust:slim currently resolves to Debian 13 (trixie, GLIBC 2.39).
FROM docker.io/library/debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/cargo/bin/alumet-agent /usr/local/bin/alumet-agent
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

CMD ["/usr/local/bin/entrypoint.sh"]
